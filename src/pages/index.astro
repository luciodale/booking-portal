---
import type { Locale } from "@/i18n/types";
import { defaultLocale } from "@/i18n/types";
import { t } from "@/i18n/t";
import { localePath } from "@/i18n/locale-path";
import PageLayout from "@/layouts/PageLayout.astro";
import { SearchBarIsland } from "@/features/public/search/ui/SearchBarIsland";
import Button from "@/modules/ui/astro/Button.astro";
import Heading from "@/modules/ui/astro/Heading.astro";
import Hero from "@/modules/ui/astro/Hero.astro";

export const prerender = true;

const locale = (Astro.currentLocale ?? defaultLocale) as Locale;
---

<PageLayout title={t(locale, "home.pageTitle")}>
  <Hero
    badge={t(locale, "home.badge")}
    title={t(locale, "home.title")}
    titleGradient={t(locale, "home.titleGradient")}
    subtitle={t(locale, "home.subtitle")}
    backgroundVideo="/hero-video.mp4"
    backgroundImage="/images/home/hero-fallback.webp"
  >
    <div class="mt-8 w-full max-w-2xl mx-auto animate-slide-up opacity-0" style="animation-delay: 0.8s">
      <SearchBarIsland client:only="react" locale={locale} />
    </div>
  </Hero>

  <!-- Elite Collection — Full-bleed cinematic section -->
  <section class="relative h-screen flex items-center justify-center overflow-hidden">
    <img
      src="/images/home/elite-villa.webp"
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-black/30"></div>

    <div class="relative z-10 text-center px-6 max-w-3xl mx-auto">
      <span class="badge-elite mb-8 inline-flex animate-fade-in opacity-0" style="animation-delay: 0.2s">
        <i data-lucide="crown" class="w-3.5 h-3.5 fill-current"></i>
        Elite
      </span>
      <h2 class="text-4xl sm:text-5xl md:text-7xl font-bold text-white tracking-tight leading-[1.1] animate-slide-up opacity-0" style="animation-delay: 0.4s">
        {t(locale, "home.eliteTagline")}
      </h2>
      <p class="mt-6 text-lg md:text-xl text-white/70 max-w-xl mx-auto leading-relaxed animate-slide-up opacity-0" style="animation-delay: 0.6s">
        {t(locale, "home.eliteDescription")}
      </p>
      <div class="mt-10 animate-slide-up opacity-0" style="animation-delay: 0.8s">
        <a
          href={localePath(locale, "/elite")}
          class="inline-flex items-center gap-2 px-8 py-4 text-sm font-semibold rounded-full bg-white text-black hover:bg-white/90 transition-all duration-200 hover:scale-105"
        >
          {t(locale, "home.eliteCta")}
          <i data-lucide="arrow-right" class="w-4 h-4"></i>
        </a>
      </div>
    </div>
  </section>

  <!-- Standard Collection — Marketing -->
  <section class="py-24 px-6 bg-card relative overflow-hidden">
    <div class="container mx-auto relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <!-- Copy side -->
        <div class="flex flex-col lg:order-1 lg:pr-8">
          <p class="text-sm font-semibold tracking-widest uppercase text-primary mb-4">Standard Collection</p>
          <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight leading-[1.1] mb-6">
            {t(locale, "home.standardTagline")}
          </h2>
          <p class="text-lg text-muted-foreground leading-relaxed mb-10 max-w-md">
            {t(locale, "home.standardDescription")}
          </p>

          <div class="flex flex-col gap-6 mb-12">
            {[
              { icon: "shield-check", text: t(locale, "home.standardFeature1") },
              { icon: "badge-percent", text: t(locale, "home.standardFeature2") },
              { icon: "calendar-check", text: t(locale, "home.standardFeature3") },
            ].map((feature) => (
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center shrink-0">
                  <i data-lucide={feature.icon} class="w-5 h-5 text-primary"></i>
                </div>
                <span class="text-[15px] font-medium">{feature.text}</span>
              </div>
            ))}
          </div>

          <div>
            <a
              href={localePath(locale, "/standard")}
              class="inline-flex items-center gap-2 px-8 py-4 text-sm font-semibold rounded-full border border-border bg-background hover:border-primary hover:text-primary transition-all duration-200 group"
            >
              {t(locale, "home.standardCta")}
              <i data-lucide="arrow-right" class="w-4 h-4 group-hover:translate-x-1 transition-transform"></i>
            </a>
          </div>
        </div>

        <!-- Visual side -->
        <div class="relative lg:order-2">
          <div class="grid grid-cols-2 gap-4">
            <div class="aspect-[3/4] rounded-2xl overflow-hidden shadow-lg translate-y-8">
              <img
                src="/images/home/standard-interior.webp"
                alt="Standard property interior"
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
            <div class="aspect-[3/4] rounded-2xl overflow-hidden shadow-lg -translate-y-8">
              <img
                src="/images/home/standard-living.webp"
                alt="Standard property living room"
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
          </div>
          <div class="absolute -bottom-6 -right-6 w-32 h-32 rounded-full bg-secondary blur-2xl opacity-50"></div>
          <div class="absolute -top-6 -left-6 w-24 h-24 rounded-full bg-muted blur-2xl opacity-50"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24 px-6 relative overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute top-0 left-1/4 w-96 h-96 rounded-full bg-primary/10 blur-[100px]"></div>
      <div class="absolute bottom-0 right-1/4 w-96 h-96 rounded-full bg-accent/10 blur-[100px]"></div>
    </div>

    <div class="container mx-auto relative z-10 text-center">
      <Heading level={2} class="mb-6">
        {t(locale, "home.ctaHeading", { gradient: "" }).trim()} <span class="text-gradient">{t(locale, "home.ctaGradient")}</span>
      </Heading>
      <p class="text-lg text-muted-foreground max-w-xl mx-auto mb-10">
        {t(locale, "home.ctaDescription")}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href={localePath(locale, "/backoffice")}>{t(locale, "home.becomeHost")}</Button>
        <Button variant="secondary" href={localePath(locale, "/about")}>{t(locale, "home.learnMore")}</Button>
      </div>
    </div>
  </section>
</PageLayout>
