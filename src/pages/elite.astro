---
import { getDb } from "@/db";
import {
  fetchCitiesByTier,
  fetchPropertiesByCity,
} from "@/features/public/browse/queries";
import { localePath } from "@/i18n/locale-path";
import { t } from "@/i18n/t";
import type { Locale } from "@/i18n/types";
import { defaultLocale } from "@/i18n/types";
import PageLayout from "@/layouts/PageLayout.astro";
import Hero from "@/modules/ui/astro/Hero.astro";
import PropertyCard from "@/modules/ui/astro/PropertyCard.astro";

export const prerender = false;

const locale = (Astro.currentLocale ?? defaultLocale) as Locale;
const db = getDb(Astro.locals.runtime.env.DB);
const cityParam = Astro.url.searchParams.get("city");
const currentPage = Math.max(
  1,
  Number(Astro.url.searchParams.get("page") || "1"),
);

const cities = cityParam ? [] : await fetchCitiesByTier(db, "elite");
const { properties, totalCount, totalPages } = cityParam
  ? await fetchPropertiesByCity(db, "elite", cityParam, currentPage)
  : { properties: [], totalCount: 0, totalPages: 0 };
---

<PageLayout
  title={cityParam
    ? t(locale, "elite.cityTitle", { city: cityParam })
    : t(locale, "elite.pageTitle")}
  description={t(locale, "elite.description")}
  showMarble
>
  <Hero
    badge={t(locale, "elite.badge")}
    title={t(locale, "elite.title")}
    titleGradient={t(locale, "elite.titleGradient")}
    subtitle={t(locale, "elite.subtitle")}
    cityName={cityParam}
    height="medium"
  />

  {
    !cityParam ? (
      <section class="py-20 px-6">
        <div class="container mx-auto max-w-5xl">
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-5">
            {cities.map((city, index) => (
              <a
                href={`${localePath(locale, "/elite")}?city=${encodeURIComponent(city)}`}
                class="group relative aspect-4/3 rounded-2xl overflow-hidden animate-slide-up opacity-0 cursor-pointer border border-primary/15 transition-[border-color] duration-500 hover:border-primary/40"
                style={`animation-delay: ${0.1 + index * 0.06}s`}
              >
                <div class="absolute inset-0 bg-city-card" />

                <div class="absolute top-4 right-4 w-10 h-10 rounded-full bg-primary transition-transform duration-700 ease-[cubic-bezier(0.4,0,0,1)] group-hover:scale-[18] z-10" />

                <div class="absolute top-4 right-4 w-10 h-10 flex items-center justify-center z-20">
                  <i
                    data-lucide="arrow-up-right"
                    class="w-5 h-5 text-primary-foreground"
                  />
                </div>

                <div class="absolute bottom-0 left-0 right-0 p-5 z-20">
                  <h3 class="text-3xl md:text-4xl font-light tracking-tight leading-none text-city-card-foreground transition-colors duration-500 group-hover:text-primary-foreground">
                    {city}
                  </h3>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    ) : (
      <section class="py-16 px-6">
        <div class="container mx-auto">
          <div class="mb-8 flex items-center gap-2 text-sm text-muted-foreground">
            <a
              href={localePath(locale, "/elite")}
              class="hover:text-foreground transition-colors flex items-center gap-1"
            >
              <i data-lucide="arrow-left" class="w-4 h-4" />
              {t(locale, "common.allCities")}
            </a>
            <span>/</span>
            <span class="text-foreground">{cityParam}</span>
            <span class="ml-auto">
              {totalCount}{" "}
              {totalCount === 1
                ? t(locale, "common.property")
                : t(locale, "common.properties")}
            </span>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            {properties.map((property, index) => (
              <div
                class="animate-slide-up opacity-0"
                style={`animation-delay: ${0.1 + index * 0.1}s`}
              >
                <PropertyCard {...property} target="_blank" locale={locale} />
              </div>
            ))}
          </div>

          {totalPages > 1 && (
            <nav class="mt-12 flex justify-center items-center gap-2">
              {currentPage > 1 && (
                <a
                  href={`${localePath(locale, "/elite")}?city=${encodeURIComponent(cityParam)}&page=${currentPage - 1}`}
                  class="px-4 py-2 rounded-lg bg-card border border-border hover:bg-muted transition-colors text-sm"
                >
                  {t(locale, "common.previous")}
                </a>
              )}
              {Array.from({ length: totalPages }, (_, i) => i + 1).map(
                (page) => (
                  <a
                    href={`${localePath(locale, "/elite")}?city=${encodeURIComponent(cityParam)}&page=${page}`}
                    class:list={[
                      "px-4 py-2 rounded-lg text-sm transition-colors",
                      page === currentPage
                        ? "bg-primary text-primary-foreground"
                        : "bg-card border border-border hover:bg-muted",
                    ]}
                  >
                    {page}
                  </a>
                ),
              )}
              {currentPage < totalPages && (
                <a
                  href={`${localePath(locale, "/elite")}?city=${encodeURIComponent(cityParam)}&page=${currentPage + 1}`}
                  class="px-4 py-2 rounded-lg bg-card border border-border hover:bg-muted transition-colors text-sm"
                >
                  {t(locale, "common.next")}
                </a>
              )}
            </nav>
          )}
        </div>
      </section>
    )
  }
</PageLayout>
